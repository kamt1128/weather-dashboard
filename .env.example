# === Database (PostgreSQL) ===
POSTGRES_USER=weather
POSTGRES_PASSWORD=weather
POSTGRES_DB=weather
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://weather:weather@db:5432/weather

# === Django ===
DJANGO_SECRET_KEY=replace_me_with_a_50_char_random_secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# En produccion: dominio de Render, ej: weather-backend.onrender.com

# === CORS (production only — leave blank for dev) ===
# Comma-separated. Ej: https://kennyalejandro.github.io
CORS_ALLOWED_ORIGINS=

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# === OpenWeather API ===
# Crea cuenta gratis en https://openweathermap.org/api
OPENWEATHER_API_KEY=

# === Frontend (Vite — usadas en build/dev) ===
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# === Logging ===
DJANGO_LOG_LEVEL=INFO
